# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# Virtual env
.venv/
venv/

# Kuzu database
graph/

# Generated logs
extension_requests.jsonl
potential_duplicates.jsonl

# Local secrets (never committed)
Important/
.secrets/
*.key
*.pem

# Personal Claude Code local settings
.claude/settings.local.json

# User-local notes / vaults that may sit alongside the repo
Brain/
notes/
.obsidian/

# Project payloads — ignore every subdir by default, then allow the
# public examples explicitly. Keeps personal project names out of the
# published .gitignore.
projects/*/
!projects/brain/
!projects/ripgrep/

# Experiment artifacts
experiments/*/corpus/
experiments/*/results/
experiments/*/extractions/

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

ui/frontend/node_modules/
ui/frontend/dist/
